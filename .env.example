# =============================================================================
# changedetection.io — Railway Deployment Configuration
# Full env reference: https://github.com/dgtlmoon/changedetection.io/wiki
# =============================================================================

# --- Server ---
# Port (Railway sets this automatically; override if needed)
# PORT=5000

# Log level: TRACE, DEBUG (default), INFO, SUCCESS, WARNING, ERROR, CRITICAL
# LOGGER_LEVEL=DEBUG

# Base URL of your instance (appears in notification alerts)
# BASE_URL=https://your-app.railway.app

# Respect X-Forwarded-* headers when behind Railway's reverse proxy
USE_X_SETTINGS=1

# Hide the Referer header from monitored sites
# HIDE_REFERER=true

# --- Fetching ---
# Number of parallel fetch workers (default: 10)
# FETCH_WORKERS=10

# Minimum seconds between rechecks (overrides per-watch minimum; 0 = disabled)
# MINIMUM_SECONDS_RECHECK_TIME=3

# Allow watching local files (file:/// URIs) — security implications!
# ALLOW_FILE_URI=false

# --- Browser (Playwright) ---
# URL to a Playwright-compatible browser for JS-rendered pages
# PLAYWRIGHT_DRIVER_URL=ws://browser:3000

# --- Privacy ---
# Disable version check / telemetry
# DISABLE_VERSION_CHECK=true

# Disable all LLM / AI features
# LLM_FEATURES_DISABLED=true

# --- Proxy ---
# HTTP proxy for outgoing requests
# HTTP_PROXY=socks5h://proxy:1080
# HTTPS_PROXY=socks5h://proxy:1080
# NO_PROXY=localhost,192.168.0.0/24

# --- SSL ---
# Railway handles TLS at the edge. Only set these if you need server-side TLS.
# LISTEN_HOST=0.0.0.0
# SSL_CERT_FILE=cert.pem
# SSL_PRIVKEY_FILE=privkey.pem

# --- Timezone ---
# Valid timezone name (for scheduled watch checking)
# TZ=America/New_York
# LC_ALL=en_US.UTF-8

# --- Screenshots ---
# Maximum height of notification screenshots in pixels
# SCREENSHOT_MAX_HEIGHT=16000

# --- Plugins ---
# Extra Python packages to install (space-separated)
# EXTRA_PACKAGES=changedetection.io-osint-processor
